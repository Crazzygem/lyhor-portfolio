---
import projects from '../data/projects.json';
---

<section id="work" class="section bg-white">
  <div class="container">
    <div class="fade-in">
      <h2 class="heading text-center">My Work</h2>
      <p class="text-center text-primary-500 mb-12 max-w-2xl mx-auto">
        A selection of packaging and branding projects showcasing creative design solutions
      </p>
      
      <!-- Masonry Grid -->
      <div class="masonry">
        {projects.map((project) => (
          <div class="masonry-item">
            <div class="card overflow-hidden">
              <img src={project.src} alt={project.alt} class="w-full h-auto" loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
