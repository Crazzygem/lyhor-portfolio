<section id="contact" class="section bg-white">
  <div class="container">
    <div class="fade-in" data-animate="fade-in">
      <h2 class="heading text-center">Get In Touch</h2>
      <p class="text-center text-primary-500 mb-12 max-w-2xl mx-auto">
        I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision
      </p>
      
      <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-8">
        <!-- Email -->
        <div class="card p-8 text-center hover:shadow-xl transition-shadow duration-300">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary-100 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-primary-800 mb-2">Email</h3>
          <a href="mailto:Lyhorkimhornn168@gmail.com" class="text-primary-500 hover:text-primary-700 transition-colors break-all">
            Lyhorkimhornn168@gmail.com
          </a>
        </div>
        
        <!-- Phone -->
        <div class="card p-8 text-center hover:shadow-xl transition-shadow duration-300">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary-100 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-primary-800 mb-2">Phone</h3>
          <a href="tel:+85586735863" class="text-primary-500 hover:text-primary-700 transition-colors">
            +855 86 73 58 63
          </a>
        </div>
        
        <!-- Location -->
        <div class="card p-8 text-center hover:shadow-xl transition-shadow duration-300">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary-100 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-primary-800 mb-2">Location</h3>
          <p class="text-primary-500">
            Tuek Tlah, Sen Sok<br />
            Phnom Penh, Cambodia
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

