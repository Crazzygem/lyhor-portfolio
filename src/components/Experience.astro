---
import { experiences, education } from '../data/experience.json';
---

<section id="experience" class="section bg-primary-50">
  <div class="container">
    <div class="fade-in">
      <h2 class="heading text-center">Experience</h2>
      
      <!-- Work Experience -->
      <div class="mb-16">
        <h3 class="subheading text-primary-700 mb-8">Work Experience</h3>
        <div class="space-y-8">
          {experiences.map((exp) => (
            <div class="card p-6 md:p-8">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
                <div>
                  <h4 class="text-xl font-semibold text-primary-800">{exp.title}</h4>
                  <p class="text-primary-500">{exp.company}</p>
                </div>
                <span class="text-sm text-primary-400 mt-2 md:mt-0">{exp.period}</span>
              </div>
              <ul class="space-y-2">
                {exp.description.map((item) => (
                  <li class="flex items-start text-primary-600">
                    <span class="w-2 h-2 bg-primary-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Education -->
      <div>
        <h3 class="subheading text-primary-700 mb-8">Education</h3>
        <div class="space-y-6">
          {education.map((edu) => (
            <div class="card p-6">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                  <h4 class="text-lg font-semibold text-primary-800">{edu.degree}</h4>
                  <p class="text-primary-500">{edu.school}</p>
                  <p class="text-primary-400 text-sm mt-1">{edu.description}</p>
                </div>
                <span class="text-sm text-primary-400 mt-2 md:mt-0">{edu.period}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
