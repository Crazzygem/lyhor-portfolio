---
import navItems from '../data/nav.json';
---

<nav class="fixed top-0 left-0 right-0 bg-white/90 backdrop-blur-md z-50 border-b border-primary-100">
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="#home" class="text-xl font-bold text-primary-800">
        Lyhor<span class="text-primary-400">.</span>
      </a>
      
      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href}
              class="text-primary-600 hover:text-primary-800 font-medium transition-colors duration-300 nav-link"
              data-nav-section={item.href.slice(1)}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      
      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn"
        class="md:hidden p-2 text-primary-600 hover:text-primary-800"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
    
    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <ul class="space-y-4">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href}
              class="block text-primary-600 hover:text-primary-800 font-medium transition-colors duration-300"
              data-nav-section={item.href.slice(1)}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  
  // Close mobile menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
